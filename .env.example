# Apify — console.apify.com > Settings > Integrations
APIFY_TOKEN=

# Groq — console.groq.com/keys (free tier)
GROQ_API_KEY=

# Supabase — project Settings > API (service_role key, this runs server-side only)
SUPABASE_URL=
SUPABASE_KEY=

# Discord — channel Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=
# Optional separate webhook for the end-of-run digest channel (falls back to DISCORD_WEBHOOK_URL)
DISCORD_DIGEST_WEBHOOK_URL=
# Optional separate webhook for REVIEW-tier leads (score 45-64, "your judgment").
# Keeps the main channel high-confidence only. Falls back to DISCORD_WEBHOOK_URL.
DISCORD_REVIEW_WEBHOOK_URL=
# Optional dedicated channel for Hacker News leads (cold-email outreach), kept separate
# from the X lead channels. Falls back to DISCORD_WEBHOOK_URL.
DISCORD_HN_WEBHOOK_URL=
# Optional test-channel webhook used automatically in --dry-run
DISCORD_TEST_WEBHOOK_URL=
